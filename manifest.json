{
  "manifest_version": 3,
  "name": "MLS Price Per Sq Ft Calculator",
  "version": "1.0.0",
  "description": "Calculates live price per square foot from selected comparable sales in MLS.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "MLS PPSF"
  }
}
